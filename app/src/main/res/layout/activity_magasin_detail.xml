<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/fond_clair"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🔥 Bouton Retour -->
    <Button
        android:id="@+id/button_retour"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:backgroundTint="@color/rose"
        android:textColor="@android:color/white"
        android:layout_gravity="start"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/button_itineraire"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Itinéraire"
        android:backgroundTint="@color/rose"
        android:textColor="@android:color/white"
        android:layout_gravity="start"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/text_nom_magasin"
        android:text="Nom"
        android:textSize="24sp"
        android:textColor="@color/rose_fonce"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/text_adresse_magasin"
        android:text="Adresse"
        android:textSize="18sp"
        android:textColor="@color/texte"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/text_stock_magasin"
        android:text="Stock"
        android:textSize="16sp"
        android:textColor="@color/texte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>
