<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/fond_clair"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/rose"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/text_nom_magasin"
                android:text="Nom du magasin"
                android:textSize="24sp"
                android:textColor="@color/rose_fonce"
                android:layout_marginBottom="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/text_adresse_magasin"
                android:text="Adresse"
                android:textSize="18sp"
                android:textColor="@color/texte"
                android:layout_marginBottom="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/text_stock_magasin"
                android:text="Stock :"
                android:textSize="16sp"
                android:textColor="@color/texte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/button_itineraire"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Itinéraire"
                android:backgroundTint="@color/rose"
                android:textColor="@android:color/white"
                android:layout_gravity="center"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>